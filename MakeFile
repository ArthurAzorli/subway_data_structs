# Compiler and flags
CC = gcc
CFLAGS = -Wall -Wextra -O2
LIBS = -lmd

# Source files (list explicitly)
SRC = main.c program.c \
      service/database/data_base_repository.c \
      service/input/input_repository.c \
      service/database/header_repository.c \
      domain/subway_record.c \
      domain/search_criteria.c \
      core/utils/errors.c

# Header files (list explicitly too)
HEADERS = program.h \
          service/database/data_base_repository.h \
          service/input/input_repository.h \
          service/database/header_repository.h \
          domain/subway_record.h \
          domain/search_criteria.h \
          core/utils/errors.h \
          core/utils/types.h \
          config.h

# Output binary
TARGET = programaTrab

# Default rule: compile the program
all: $(TARGET)

$(TARGET): $(SRC) $(HEADERS)
    $(CC) -o $(TARGET) $(SRC) $(CFLAGS) $(LIBS)

# Run the program
run:
    ./$(TARGET)

# Clean build artifacts
clean:
    rm -f $(TARGET) *.o
